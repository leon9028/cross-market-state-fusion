# Polymarket CLOB API (User Channel + placing orders)
# Derive from your Polymarket account; see https://docs.polymarket.com/developers/CLOB/authentication
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# CLOB client for placing orders (helpers/clob_client.py)
# PK = private key; FUNDER = proxy/funder address (for signature_type=2)
# CLOB_API_URL defaults to https://clob.polymarket.com if unset
# CLOB_API_URL=https://clob.polymarket.com
PK=
FUNDER=

# Optional: RL training overrides (strategies/rl_torch.py)
# RL_BUFFER_SIZE=256
# RL_BATCH_SIZE=64

# Optional: Dashboard port (dashboard.py, dashboard_cinematic.py)
# PORT=5050
